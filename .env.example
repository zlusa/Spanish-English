# Environment variables
#
# Use EITHER:
#   - This file copied to `.env` at the repo root (same folder as package.json), OR
#   - `apps/realtime/.env`
# Keys in apps/realtime/.env override the repo root `.env`.

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

OPENAI_API_KEY=
# Optional:
# OPENAI_TRANSLATION_MODEL=gpt-realtime-translate

PORT=8787
# Optional — same secret must be entered in the web UI "Team code" field:
# TRAINING_JOIN_CODE=your-shared-secret

# Optional — comma-separated browser origins if not using Vite proxy:
# CORS_ORIGIN=http://localhost:5173

# --- Web / Vite (apps/web): optional TURN for OpenAI translation WebRTC (corporate firewalls) ---
# Vite only reads these when building apps/web — set them in apps/web/.env or Vercel env for the web project.
# VITE_TURN_URLS=turns:turn.example.com:443?transport=tcp,turn:turn.example.com:3478
# VITE_TURN_USERNAME=your-turn-user
# VITE_TURN_CREDENTIAL=your-turn-password
# Or pass a full JSON array of RTCIceServer objects:
# VITE_WEBRTC_ICE_SERVERS=[{"urls":["turns:turn.example.com:443?transport=tcp"],"username":"u","credential":"p"}]
